<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OpenNebula Cloud Verification Report</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@300;400;600;700&display=swap');
  :root{--one-blue:#1a7ba4;--one-blue-light:#e8f4f9;--one-blue-mid:#c2dfed;--bg:#fff;--surface:#f8fafc;--surface2:#f1f5f9;--border:#e2e8f0;--text:#0f172a;--muted:#64748b;--pass:#15803d;--pass-bg:#f0fdf4;--pass-bd:#bbf7d0;--fail:#b91c1c;--fail-bg:#fef2f2;--fail-bd:#fecaca;--warn:#b45309;--warn-bg:#fffbeb;--warn-bd:#fde68a;--info:#1e40af;--info-bg:#eff6ff;--info-bd:#bfdbfe;--mono:'IBM Plex Mono',monospace}
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--bg);color:var(--text);font-family:'IBM Plex Sans',sans-serif;font-size:14px;line-height:1.6}
  .wrap{max-width:1080px;margin:0 auto;padding:40px 24px}
  .header{display:flex;align-items:center;gap:24px;padding:24px 32px;background:var(--bg);border:1px solid var(--border);border-left:4px solid var(--one-blue);border-radius:10px;margin-bottom:24px}
  .header-logo img{height:52px;width:auto;display:block}
  .header-div{width:1px;height:52px;background:var(--border);flex-shrink:0}
  .hm{flex:1}.hm h1{font-size:19px;font-weight:700;margin-bottom:4px}.hm p{color:var(--muted);font-size:12px;line-height:1.8}.hm strong{color:var(--one-blue)}
  .header-meta{display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0}
  .role-pill{display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:999px;font-size:11px;font-weight:700;font-family:var(--mono);letter-spacing:.5px;background:var(--one-blue-light);border:1px solid var(--one-blue-mid);color:var(--one-blue)}
  .ts{font-size:11px;color:var(--muted);font-family:var(--mono)}
  .banner{padding:13px 20px;border-radius:8px;margin-bottom:24px;display:flex;align-items:center;gap:12px;font-weight:600;font-size:14px;border-left-width:4px;border-left-style:solid}
  .status-pass{background:var(--pass-bg);border-color:var(--pass);color:var(--pass)}.status-fail{background:var(--fail-bg);border-color:var(--fail);color:var(--fail)}.status-warn{background:var(--warn-bg);border-color:var(--warn);color:var(--warn)}
  .cards{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px}.card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:18px 16px;text-align:center;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:96px}.card .num{display:block;width:100%;text-align:center;font-size:32px;font-weight:700;font-family:var(--mono);line-height:1;margin-bottom:4px}.card .lbl{display:block;width:100%;text-align:center;font-size:11px;text-transform:uppercase;letter-spacing:1px;color:var(--muted)}
  .cp{border-top:3px solid var(--pass)}.cp .num{color:var(--pass)}.cf{border-top:3px solid var(--fail)}.cf .num{color:var(--fail)}.cw{border-top:3px solid var(--warn)}.cw .num{color:var(--warn)}.ct{border-top:3px solid var(--one-blue)}.ct .num{color:var(--one-blue)}
  .pgwrap{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:18px 20px;margin-bottom:24px}.pglbl{display:flex;justify-content:space-between;margin-bottom:8px;font-size:12px;color:var(--muted);font-weight:600}.pgbar{height:8px;background:var(--border);border-radius:999px;overflow:hidden}.pgfill{height:100%;border-radius:999px;background:linear-gradient(90deg,var(--pass),var(--one-blue));transition:width .9s cubic-bezier(.4,0,.2,1)}
  .arch-section{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:20px;margin-bottom:24px}.arch-fe{text-align:center;padding:10px 20px;background:var(--one-blue-light);border:1px solid var(--one-blue-mid);border-radius:8px;margin:0 auto 6px;width:230px;color:var(--one-blue);font-weight:700;font-family:var(--mono);font-size:12px}.arch-fe small{display:block;color:var(--text);font-size:11px;font-weight:400;margin-top:3px}.ac{text-align:center;color:var(--muted);font-family:var(--mono);line-height:1.2}.anet{text-align:center;padding:7px;border-radius:4px;margin:3px 0;font-size:11px;font-weight:600;letter-spacing:.5px;font-family:var(--mono)}.nm{background:var(--pass-bg);border:1px solid var(--pass-bd);color:var(--pass)}.ns{background:var(--warn-bg);border:1px solid var(--warn-bd);color:var(--warn)}.np{background:var(--info-bg);border:1px solid var(--info-bd);color:var(--info)}.anodes{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0}.anode{padding:10px;background:#faf5ff;border:1px solid #e9d5ff;border-radius:6px;text-align:center;color:#7c3aed;font-size:11px;font-family:var(--mono)}.anode strong{display:block;color:var(--text);font-size:12px;margin-bottom:3px}
  .rst-section,.data-section{margin-bottom:24px}.rst-header{width:100%;padding:11px 16px;background:var(--surface2);border:1px solid var(--border);border-bottom:none;border-radius:8px 8px 0 0;display:flex;align-items:center;justify-content:space-between;cursor:pointer;user-select:none;text-align:left}.rst-header h3,.section-title{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--muted)}.tog{color:var(--muted);font-size:16px;font-family:var(--mono)}
  .rtable,.gtable{width:100%;border-collapse:collapse;border:1px solid var(--border)}.rtable{border-radius:0 0 8px 8px;overflow:hidden}.rtable td,.gtable td{padding:11px 14px;border-bottom:1px solid var(--border);vertical-align:top;font-size:13px}.rtable tr:last-child td,.gtable tr:last-child td{border-bottom:none}.rtable tr:hover td,.gtable tr:hover td{background:var(--surface)}.gtable th{padding:8px 12px;font-size:11px;text-transform:uppercase;letter-spacing:.8px;color:var(--muted);border-bottom:2px solid var(--border);text-align:left;font-weight:700;background:var(--surface2)}.bench-table{table-layout:fixed;min-width:620px}
  .status-cell{width:96px}.badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:999px;font-size:11px;font-weight:700;font-family:var(--mono);white-space:nowrap}.bp{background:var(--pass-bg);color:var(--pass);border:1px solid var(--pass-bd)}.bf{background:var(--fail-bg);color:var(--fail);border:1px solid var(--fail-bd)}.bw{background:var(--warn-bg);color:var(--warn);border:1px solid var(--warn-bd)}.bi{background:var(--info-bg);color:var(--info);border:1px solid var(--info-bd)}
  .cn{font-weight:600;color:var(--text)}.cd{color:var(--muted);font-family:var(--mono);font-size:11px;margin-top:2px;word-break:break-word;white-space:pre-wrap}.comment{margin-top:8px;padding:9px 12px;background:#fefce8;border:1px solid #fde68a;border-left:3px solid #d97706;border-radius:6px;font-size:12px;color:#78350f;line-height:1.6}.comment-lbl{font-weight:700;color:#b45309;margin-right:6px;font-family:var(--mono);font-size:11px}
  .data-section{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:20px}.data-section .section-title{margin-bottom:14px}.table-scroll{overflow:auto}.mini-pre,pre{padding:12px 14px;background:#fff;border:1px solid var(--border);border-left:3px solid var(--one-blue);border-radius:6px;font-family:var(--mono);font-size:11px;color:var(--muted);line-height:1.7;overflow:auto;white-space:pre-wrap}.mini-pre{margin-top:4px;max-height:260px}pre{max-height:560px}.num{text-align:right;font-family:var(--mono)}.matrix-ok{background:var(--pass-bg);color:var(--pass);font-family:var(--mono);font-weight:600}.matrix-bad{background:var(--fail-bg);color:var(--fail);font-family:var(--mono);font-weight:600}.matrix-warn{background:var(--warn-bg);color:var(--warn);font-family:var(--mono);font-weight:600}
  .footer{display:flex;align-items:center;justify-content:space-between;padding-top:24px;border-top:1px solid var(--border);font-size:12px;color:var(--muted)}.footer a{color:var(--one-blue);text-decoration:none}.footer a:hover{text-decoration:underline}
  @media(max-width:640px){.cards{grid-template-columns:repeat(2,1fr)}.anodes{grid-template-columns:1fr}.header{flex-direction:column;align-items:flex-start}.header-meta{align-items:flex-start}.footer{flex-direction:column;gap:12px;align-items:flex-start}}
  @media print{body{background:#fff}.wrap{padding:20px}.rst-header{cursor:default}}
</style>
</head>
<body>

{% macro status_from(value, comment='') -%}
  {%- set text = ((value | string) ~ ' ' ~ (comment | default('') | string)) | lower -%}
  {%- if 'unreachable' in text or 'inactive' in text or 'failed' in text or 'error' in text or 'fault' in text -%}fail
  {%- elif 'warning' in text or 'skipped' in text or 'unknown' in text or ' n/a' in text -%}warn
  {%- elif value == 'ok' or value == 'reachable' or value == 'active' or value == 'enabled' or value == 'running' or 'ok -' in text or 'state=running' in text or ('packet_loss_percent' in text and ('packet_loss_percent": 0.0' in text or "packet_loss_percent': 0.0" in text or 'packet_loss_percent: 0.0' in text)) -%}pass
  {%- else -%}info
  {%- endif -%}
{%- endmacro %}

{% macro badge(status) -%}
  {%- if status == 'pass' -%}<span class="badge bp">PASS</span>
  {%- elif status == 'fail' -%}<span class="badge bf">FAIL</span>
  {%- elif status == 'warn' -%}<span class="badge bw">WARN</span>
  {%- else -%}<span class="badge bi">INFO</span>
  {%- endif -%}
{%- endmacro %}

{% macro render_value(value) -%}
  {%- if value is mapping or (value is sequence and value is not string) -%}
    <pre class="mini-pre">{{ value | to_nice_json }}</pre>
  {%- else -%}
    {%- set value_text = value | string -%}
    {%- if '\n' in value_text or value_text | trim | regex_search('^[{[]') -%}<pre class="mini-pre">{{ value_text }}</pre>
    {%- else -%}<div class="cd">{{ value_text }}</div>
    {%- endif -%}
  {%- endif -%}
{%- endmacro %}

{% macro render_check_table(items, section_title, table_id) -%}
  {%- if items | length > 0 -%}
  <section class="rst-section">
    <button class="rst-header" type="button" onclick="toggleTable('table-{{ table_id }}', 'tog-{{ table_id }}')">
      <h3>{{ section_title }} ({{ items | length }} checks)</h3><span class="tog" id="tog-{{ table_id }}">v</span>
    </button>
    <table class="rtable" id="table-{{ table_id }}"><tbody>
      {%- for k, v in items %}
      {%- set comment = ((verification_comments | default({})).get(k, '') | trim) %}
      {%- set status = status_from(v, comment) | trim %}
      <tr><td class="status-cell">{{ badge(status) }}</td><td><div class="cn">{{ k }}</div>{{ render_value(v) }}{% if comment != '' %}<div class="comment"><span class="comment-lbl">NOTE</span>{{ comment }}</div>{% endif %}</td></tr>
      {%- endfor %}
    </tbody></table>
  </section>
  {%- endif -%}
{%- endmacro %}

{% set checks = verification_result | default({}) %}
{% set comments = verification_comments | default({}) %}
{% set counts = namespace(pass=0, fail=0, warn=0, info=0) %}
{% for k, v in checks.items() %}
  {% set status = status_from(v, comments.get(k, '')) | trim %}
  {% if status == 'pass' %}{% set counts.pass = counts.pass + 1 %}{% elif status == 'fail' %}{% set counts.fail = counts.fail + 1 %}{% elif status == 'warn' %}{% set counts.warn = counts.warn + 1 %}{% else %}{% set counts.info = counts.info + 1 %}{% endif %}
{% endfor %}
{% if validation_vars.networks_verification | default(false) and network_verification_results is defined %}
  {% for net_name, net_results in network_verification_results.items() %}
    {% set status = status_from(net_results) | trim %}
    {% if status == 'pass' %}{% set counts.pass = counts.pass + 1 %}{% elif status == 'fail' %}{% set counts.fail = counts.fail + 1 %}{% elif status == 'warn' %}{% set counts.warn = counts.warn + 1 %}{% else %}{% set counts.info = counts.info + 1 %}{% endif %}
  {% endfor %}
{% endif %}
{% set total = counts.pass + counts.fail + counts.warn + counts.info %}
{% set readiness_total = counts.pass + counts.fail + counts.warn %}
{% set pct = ((counts.pass * 100 / readiness_total) | round(0, 'common')) | int if readiness_total > 0 else 0 %}
{% set overall_status = 'fail' if counts.fail > 0 else ('warn' if counts.warn > 0 else 'pass') %}
{% set arch = report_architecture | default({}) %}
{% set arch_frontends = arch.frontends | default([]) %}
{% set arch_hypervisors = arch.hypervisors | default([]) %}
{% set arch_networks = arch.networks | default([]) %}
{% set arch_pre_networks = arch_networks[:2] %}
{% set arch_post_networks = arch_networks[2:] %}

{% set ns = namespace(core_services=[], vm_tests=[], ldap=[], oneflow=[], vm_ha=[], fe_ha=[], federation=[], other=[]) %}
{% for k, v in checks.items() %}
  {% set kl = k | lower %}
  {% if 'oneflow' in kl %}{% set _ = ns.oneflow.append((k, v)) %}
  {% elif 'ldap' in kl or 'rpc2' in kl %}{% set _ = ns.ldap.append((k, v)) %}
  {% elif 'service' in kl or 'xml-rpc' in kl or 'oned version' in kl or 'repository' in kl or 'datastore' in kl or 'marketplace' in kl or 'registered kvm' in kl or 'hosts status' in kl %}{% set _ = ns.core_services.append((k, v)) %}
  {% elif 'test vm' in kl or ('storage' in kl and 'benchmark' not in kl) or 'template' in kl %}{% set _ = ns.vm_tests.append((k, v)) %}
  {% elif 'vm ha' in kl or 'fencing' in kl or 'host error' in kl %}{% set _ = ns.vm_ha.append((k, v)) %}
  {% elif 'fe ha' in kl or 'leader' in kl or 'vip' in kl or 'config diretory' in kl %}{% set _ = ns.fe_ha.append((k, v)) %}
  {% elif 'federation' in kl %}{% set _ = ns.federation.append((k, v)) %}
  {% else %}{% set _ = ns.other.append((k, v)) %}
  {% endif %}
{% endfor %}

<div class="wrap">
  <div class="header">
    <div class="header-logo"><a href="https://opennebula.io" target="_blank" rel="noopener"><img src="data:image/png;base64," alt="OpenNebula"></a></div><div class="header-div"></div>
    <div class="hm"><h1>Automated Cloud Verification Report</h1><p>Generated: <strong>{{ date }}</strong> &nbsp;.&nbsp; Repository version: <strong>{{ repo_version }}</strong></p><p>{{ arch.summary | default('OpenNebula installation verification results, network validation, benchmark data, and validation variables.') | safe }}</p></div>
    <div class="header-meta"><span class="role-pill">Cloud Verification</span><span class="ts">{{ date }}</span></div>
  </div>

  <div class="banner status-{{ overall_status }}"><span>{% if overall_status == 'fail' %}NOT READY - FIX FAILURES FIRST{% elif overall_status == 'warn' %}READY WITH WARNINGS - REVIEW NOTES{% else %}READY - ALL CHECKS PASSED{% endif %}</span></div>
  <div class="cards"><div class="card cp"><div class="num">{{ counts.pass }}</div><div class="lbl">Passed</div></div><div class="card cf"><div class="num">{{ counts.fail }}</div><div class="lbl">Failed</div></div><div class="card cw"><div class="num">{{ counts.warn }}</div><div class="lbl">Warnings</div></div><div class="card ct"><div class="num">{{ total }}</div><div class="lbl">Total</div></div></div>
  <div class="pgwrap"><div class="pglbl"><span>Overall Readiness</span><span id="pct-lbl">0%</span></div><div class="pgbar"><div class="pgfill" id="pgfill" style="width:0%"></div></div></div>

  {% if arch_frontends | length > 0 or arch_hypervisors | length > 0 or arch_networks | length > 0 %}
  <div class="arch-section">
    <div class="section-title">Target Architecture</div>
    <div style="font-family:var(--mono);font-size:12px">
      <div style="text-align:center;margin-bottom:6px">
        <div class="arch-fe">
          {{ arch.frontend_title | default('OpenNebula FE Servers' if arch_frontends | length > 1 else 'OpenNebula FE VM') }}
          {% if arch_frontends | length == 1 %}
            {% set frontend = arch_frontends[0] %}
            {% if frontend.network_ips | default([]) | length > 0 %}
          <small>{{ frontend.network_ips | join(' · ') }}</small>
            {% elif frontend.detail | default('') != '' %}
          <small>{{ frontend.detail }}</small>
            {% elif frontend.label | default('') != '' %}
          <small>{{ frontend.label }}</small>
            {% endif %}
          {% else %}
            {% for frontend in arch_frontends %}
              {% if frontend.network_ips | default([]) | length > 0 %}
          <small>{{ frontend.label }} · {{ frontend.network_ips | join(' · ') }}</small>
              {% elif frontend.detail | default('') != '' %}
          <small>{{ frontend.label }} · {{ frontend.detail }}</small>
              {% else %}
          <small>{{ frontend.label }}</small>
              {% endif %}
            {% endfor %}
          {% endif %}
        </div>
      </div>
      <div class="ac">│<br>│</div>
      {% for network in arch_pre_networks %}
      <div class="anet {{ network.class | default('nm') }}">{{ network.label }} — {{ network.cidr }}</div>
      {% endfor %}
      {% if arch_hypervisors | length > 0 %}
      <div class="anodes">
        {% for hypervisor in arch_hypervisors %}
        <div class="anode">
          <strong>{{ hypervisor.label }}{% if hypervisor.role_label | default('') != '' %} ({{ hypervisor.role_label }}){% endif %}</strong>
          {% if hypervisor.network_memberships | default([]) | length > 0 %}
            {% for membership in hypervisor.network_memberships %}
          <div>{{ membership.label }}</div>
            {% endfor %}
          {% elif hypervisor.network_ips | default([]) | length > 0 %}
          <div>{{ hypervisor.network_ips | join(' · ') }}</div>
          {% else %}
          <div>{{ hypervisor.detail }}</div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      {% endif %}
      {% for network in arch_post_networks %}
      <div class="anet {{ network.class | default('nm') }}">{{ network.label }} — {{ network.cidr }}</div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {{ render_check_table(ns.core_services, "Core Services", "core") }}
  {{ render_check_table(ns.vm_tests, "VM Instantiation Tests", "vm") }}
  {{ render_check_table(ns.oneflow, "OneFlow Smoke Test", "oneflow") }}
  {{ render_check_table(ns.ldap, "LDAP Authentication", "ldap") }}
  {{ render_check_table(ns.vm_ha, "VM High Availability", "vmha") }}
  {{ render_check_table(ns.fe_ha, "Frontend High Availability", "feha") }}
  {{ render_check_table(ns.federation, "Federation Configuration", "federation") }}
  {{ render_check_table(ns.other, "Other Checks", "other") }}

  {% if all_federation_results is defined and all_federation_results | length > 0 %}
  {% set ns_fed = namespace(normalized_checks={}) %}
  {% for host, results in all_federation_results.items() %}{% for check, value in results.items() %}{% set base_check = check | regex_replace(' on [^\\s]+$', '') %}{% if base_check not in ns_fed.normalized_checks %}{% set _ = ns_fed.normalized_checks.update({base_check: {}}) %}{% endif %}{% set _ = ns_fed.normalized_checks[base_check].update({host: value}) %}{% endfor %}{% endfor %}
  {% set fed_hosts = all_federation_results.keys() | list %}
  <section class="data-section"><div class="section-title">Federation Detailed Results (All Zones)</div><div class="table-scroll"><table class="gtable"><thead><tr><th>Check</th>{% for host in fed_hosts %}<th>{{ host }}</th>{% endfor %}</tr></thead><tbody>{% for check, host_values in ns_fed.normalized_checks.items() %}<tr><td>{{ check }}</td>{% for host in fed_hosts %}{% set result = host_values.get(host, 'N/A') %}{% set status = status_from(result) | trim %}<td>{{ badge(status) }} {{ result }}</td>{% endfor %}</tr>{% endfor %}</tbody></table></div></section>
  {% endif %}

  {% if validation_vars.networks_verification | default(false) and network_verification_results is defined and network_verification_results | length > 0 %}
  <section class="rst-section"><button class="rst-header" type="button" onclick="toggleTable('table-networks', 'tog-networks')"><h3>Virtual Networks Validation ({{ network_verification_results | length }} networks)</h3><span class="tog" id="tog-networks">v</span></button><table class="rtable" id="table-networks"><tbody>
  {% for network_name, results in network_verification_results.items() %}{% set status = status_from(results) | trim %}<tr><td class="status-cell">{{ badge(status) }}</td><td><div class="cn">{{ network_name }}</div>{% for test, value in results.items() %}<div class="cd"><strong>{{ test | trim }}:</strong></div>{{ render_value(value) }}{% endfor %}</td></tr>{% endfor %}
  </tbody></table></section>
  {% endif %}

  {% if validation_vars.run_storage_benchmark | default(false) and storage_benchmark is defined and storage_benchmark | length > 0 %}
  <section class="data-section"><div class="section-title">Storage Benchmarking Results</div>
  {% set ordered_profiles = [{'key':'rr_4k_qd1','label':'rr_4k_qd1'},{'key':'rr_4k_qd4','label':'rr_4k_qd4'},{'key':'rr_4k_qd16','label':'rr_4k_qd16'},{'key':'rr_4k_qd32','label':'rr_4k_qd32'},{'key':'rr_4k_qd64','label':'rr_4k_qd64'},{'key':'rw_4k_qd1','label':'rw_4k_qd1'},{'key':'rw_4k_qd4','label':'rw_4k_qd4'},{'key':'rw_4k_qd16','label':'rw_4k_qd16'},{'key':'rw_4k_qd32','label':'rw_4k_qd32'},{'key':'rw_4k_qd64','label':'rw_4k_qd64'},{'key':'mix_4k_70r_qd16','label':'mix_4k_70r_qd16'},{'key':'mix_64k_70r_qd16','label':'mix_64k_70r_qd16'},{'key':'seqr_128k_qd16','label':'seqr_128k_qd16'},{'key':'seqw_128k_qd16','label':'seqw_128k_qd16'},{'key':'seqr_1m_qd4','label':'seqr_1m_qd4'},{'key':'seqw_1m_qd4','label':'seqw_1m_qd4'},{'key':'syncwrite_4k_qd1','label':'syncwrite_4k_qd1'}] %}
  {% for host in storage_benchmark.keys() | list %}<div class="section-title" style="margin-top:14px">{{ host }}</div><div class="table-scroll"><table class="gtable"><thead><tr><th>Job</th><th class="num">IOPS</th><th class="num">BW (MB/s)</th><th class="num">p99 Lat (ms)</th><th class="num">Score</th></tr></thead><tbody>
  {% for item in ordered_profiles %}{% set p = (storage_benchmark[host].profiles | default([]) | selectattr('name','equalto',item.key) | list | first | default({})) %}{% set rw = p.rw | default('') %}{% if rw in ['read','randread'] %}{% set iops = p.read_iops | default(None) %}{% set bw_kib = p.read_bw_kib | default(None) %}{% set lat_ns = p.read_p99_ns | default(None) %}{% elif rw in ['write','randwrite'] %}{% set iops = p.write_iops | default(None) %}{% set bw_kib = p.write_bw_kib | default(None) %}{% set lat_ns = p.write_p99_ns | default(None) %}{% elif rw in ['rw','randrw'] %}{% set iops = (p.read_iops | default(0)) + (p.write_iops | default(0)) %}{% set bw_kib = (p.read_bw_kib | default(0)) + (p.write_bw_kib | default(0)) %}{% set lat_ns = [p.read_p99_ns | default(0), p.write_p99_ns | default(0)] | max %}{% else %}{% set iops = None %}{% set bw_kib = None %}{% set lat_ns = None %}{% endif %}{% set bw_mbs = (bw_kib / 1024) if bw_kib is not none else None %}{% set lat_ms = (lat_ns / 1000000) if lat_ns is not none else None %}{% if item.key[:3] == 'seq' %}{% set score = '★★★' if bw_mbs is not none and bw_mbs >= 300 else ('★★' if bw_mbs is not none and bw_mbs >= 150 else ('★' if bw_mbs is not none and bw_mbs >= 75 else '⚠')) %}{% else %}{% set score = '★★★' if lat_ms is not none and lat_ms <= 5 else ('★★' if lat_ms is not none and lat_ms <= 10 else ('★' if lat_ms is not none and lat_ms <= 20 else '⚠')) %}{% endif %}<tr><td>{{ item.label }}</td><td class="num">{{ iops | default('N/A') }}</td><td class="num">{% if bw_mbs is not none %}{{ bw_mbs | round(2) }}{% else %}N/A{% endif %}</td><td class="num">{% if lat_ms is not none %}{{ lat_ms | round(2) }}{% else %}N/A{% endif %}</td><td class="num">{{ score }}</td></tr>{% endfor %}
  </tbody></table></div>{% endfor %}</section>
  {% endif %}

  {% if validation_vars.run_network_benchmark | default(false) and network_benchmark is defined and network_benchmark | length > 0 %}
  <section class="data-section"><div class="section-title">Network Benchmarking Results</div><div class="section-title" style="margin-top:14px">Throughput (iperf3)</div><div class="table-scroll"><table class="gtable bench-table"><colgroup><col style="width:38%"><col style="width:38%"><col style="width:24%"></colgroup><thead><tr><th>Client host</th><th>Server</th><th class="num">Throughput</th></tr></thead><tbody>{% for host, data in network_benchmark.items() %}{% if data.iperf_results is defined and data.iperf_results.results is defined %}{% for it in data.iperf_results.results %}{% set bps = it.stdout | default('0') | float %}{% set server_name = ip_to_hostname.get(it.item) if ip_to_hostname is defined else None %}<tr><td>{{ host }}</td><td>{{ server_name | default(it.item, true) }}</td><td class="num">{{ '%.2f' | format(bps / 1000000.0) }} Mbps</td></tr>{% endfor %}{% else %}<tr><td colspan="3">No iperf3 results for {{ host }}</td></tr>{% endif %}{% endfor %}</tbody></table></div><div class="section-title" style="margin-top:18px">Ping (average RTT)</div><div class="table-scroll"><table class="gtable bench-table"><colgroup><col style="width:38%"><col style="width:38%"><col style="width:24%"></colgroup><thead><tr><th>Source host</th><th>Destination</th><th class="num">Avg RTT</th></tr></thead><tbody>{% for host, data in network_benchmark.items() %}{% if data.ping_exec is defined and data.ping_exec.results is defined %}{% for it in data.ping_exec.results %}{% set rtt_raw = it.stdout | default('') %}{% set dest_name = ip_to_hostname.get(it.item) if ip_to_hostname is defined else None %}<tr><td>{{ host }}</td><td>{{ dest_name | default(it.item, true) }}</td><td class="num">{% if rtt_raw != '' and rtt_raw != 'null' %}{{ '%.2f' | format(rtt_raw | float) }} ms{% else %}N/A{% endif %}</td></tr>{% endfor %}{% else %}<tr><td colspan="3">No ping results for {{ host }}</td></tr>{% endif %}{% endfor %}</tbody></table></div></section>
  {% endif %}

  {% if validation_vars.run_conn_matrix | default(false) and conn_results_matrix is defined and conn_results_matrix | length > 0 %}
  {% set all_hosts = conn_results_matrix.keys() | list %}
  <section class="data-section"><div class="section-title">Connectivity Matrix</div><div class="table-scroll"><table class="gtable"><thead><tr><th>From / To</th>{% for dst in all_hosts %}<th>{{ dst }}</th>{% endfor %}</tr></thead><tbody>{% for src in all_hosts %}<tr><td><strong>{{ src }}</strong></td>{% for dst in all_hosts %}{% if src == dst %}<td class="matrix-warn">self</td>{% else %}{% set result_element = (conn_results_matrix[src] | dict2items | selectattr('key','search',dst + '.json$') | map(attribute='value') | list) %}{% if result_element | length != 1 %}<td class="matrix-warn">missing</td>{% else %}{% set result = result_element | first %}{% if result.packet_loss_percent is defined %}<td class="{{ 'matrix-ok' if result.packet_loss_percent == 0.0 else 'matrix-bad' }}">{{ result.packet_loss_percent }}%</td>{% else %}<td class="matrix-bad">missing</td>{% endif %}{% endif %}{% endif %}{% endfor %}</tr>{% endfor %}</tbody></table></div></section>
  {% endif %}

  <section class="data-section"><div class="section-title">Variables Used For Validation</div><pre>{{ validation_vars | to_nice_yaml }}</pre></section>
  <div class="footer"><div>OpenNebula Cloud Verification</div><div><a href="https://docs.opennebula.io/" target="_blank" rel="noopener">OpenNebula Docs</a>&nbsp;.&nbsp;<a href="https://github.com/OpenNebula/one-deploy" target="_blank" rel="noopener">one-deploy GitHub</a></div></div>
</div>
<script>
var PCT={{ pct }};
window.addEventListener('load',function(){var fill=document.getElementById('pgfill');var lbl=document.getElementById('pct-lbl');if(fill&&lbl){setTimeout(function(){fill.style.width=PCT+'%';lbl.textContent=PCT+'% passing';},150);}});
function toggleTable(tableId,toggleId){var table=document.getElementById(tableId);var toggle=document.getElementById(toggleId);if(!table||!toggle)return;if(table.style.display==='none'){table.style.display='';toggle.textContent='v';}else{table.style.display='none';toggle.textContent='>';}}
</script>
</body>
</html>
